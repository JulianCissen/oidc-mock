{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Attach to process",
            "type": "node",
            "request": "attach",
            "port": 9229,
            "localRoot": "${workspaceFolder}/packages/backend",
            "restart": true,
            "resolveSourceMapLocations": [
                "${workspaceFolder}/**",
                "!**/node_modules/**"
            ],
            "skipFiles": [
                // Node.js internal core modules
                "<node_internals>/**",
                // Ignore all dependencies (optional)
                //"${workspaceFolder}/node_modules/**",
            ],
        }
    ]
}