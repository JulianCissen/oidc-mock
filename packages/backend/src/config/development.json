{
    "provider": {
        "iss": "https://localhost:${PORT}"
    },
    "clients": [
        {
            "client_id": "client",
            "client_secret": "secret",
            "application_type": "web",
            "redirect_uris": ["https://localhost:${PORT}/callback", "https://localhost:${PORT}/silent-renew.html"],
            "post_logout_redirect_uris": ["https://localhost:${PORT}"],
            "grant_types": ["authorization_code", "refresh_token"],
            "tokenLifetimes": {
                "accessToken": 7200,
                "authorizationCode": 600,
                "backchannelAuthenticationRequest": 600,
                "clientCredentials": 600,
                "deviceCode": 600,
                "grant": 1209600,
                "idToken": 3600,
                "interaction": 3600,
                "refreshToken": 604800,
                "session": 86400
            }
        }
    ]
}